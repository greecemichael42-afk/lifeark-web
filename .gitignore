# ===== Life Ark — allowlist =====
# Only the PUBLIC website ships to GitHub. Everything else (the paid book,
# client/work files, source assets, backups, certificates, quizzes) stays LOCAL.

# 1) ignore everything by default
/*

# 2) keep the public site files
!/.gitignore
!/.nojekyll
!/index.html
!/therapy.html
!/academy.html
!/books.html
!/felsala.html
!/article-bpd.html
!/article-adhd.html
!/article-basira.html
!/articles.html
!/CNAME
!/robots.txt
!/sitemap.xml
!/assets/

# 3) inside assets: ignore all, then keep ONLY the files the site references
/assets/*
!/assets/rokoub-sample.pdf
!/assets/clear-mind-sample.pdf
!/assets/felsala-white.png
!/assets/felsala-poster.png
!/assets/life-ark-intake-form.pdf
# 4) extracted page media (de-base64): ship the whole img folder
!/assets/img/
# 5) shared stylesheet + script (extracted from index.html)
!/assets/css/
!/assets/js/
